# Recommended Git LFS tracking for large binary assets.
# To enable LFS on your machine run: `git lfs install` and then `git lfs track "*.pt" "*.pth" "*.ckpt" "*.h5" "*.zip" "*.tar.gz" "data/*"`
# This file lists common patterns that should be stored with Git LFS if you enable it.
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
data/** filter=lfs diff=lfs merge=lfs -text
models/** filter=lfs diff=lfs merge=lfs -text
embeddings/** filter=lfs diff=lfs merge=lfs -text
