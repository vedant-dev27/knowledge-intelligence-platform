# .gitignore for Python projects (ignore large files & data)
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv/
venv/
ENV/
env/

# Editor and IDE
.vscode/
.idea/

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Testing / linters
.pytest_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Logs and temp files
*.log
.cache/

# OS files
.DS_Store
Thumbs.db

# Data, models and large files (project-specific)
data/
datasets/
models/
experiments/*/dataset/
experiments/large_dataset/dataset/
experiments/qdrant-wiki/

# Large archives and binary blobs
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.rar
*.7z

# Database / disk images
*.sqlite3
*.db
*.sqlite

# Raw and binary data
*.bin
*.raw
*.dat

# NumPy / serialized arrays
*.npy
*.npz

# Model checkpoints
*.h5
*.ckpt
*.pth
*.pt

# Vector stores / indexes
faiss_index/
vector_store/
vectors/
embeddings/
indexes/

# Local settings and secrets
local_settings.py
*.env
.env.*
